APP_NAME=LexiCounsel API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://lexicounsel:change-me@localhost:5432/lexicounsel
UPLOAD_DIR=/app/data/uploads
FAISS_INDEX_PATH=/app/data/indexes/faiss
BM25_INDEX_PATH=/app/data/indexes/bm25_index.json
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_BASE_URL=
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=LexiCounsel
RRF_K=60
DEFAULT_TOP_K=6
CHUNK_SIZE=800
CHUNK_OVERLAP=150
EVALUATION_MIN_SCORE=7
MAX_REFINEMENT_ATTEMPTS=1
CORS_ORIGINS=["http://localhost:3000"]
REQUEST_TIMEOUT_SECONDS=90

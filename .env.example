# ── LexiCounsel Environment Variables ────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── App ───────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
APP_BASE_URL=https://yourdomain.com          # public URL of your frontend

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=lexicounsel
POSTGRES_USER=lexicounsel
POSTGRES_PASSWORD=change-me-use-a-strong-password

# ── Auth ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-random-hex-string

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# Optional: use a compatible proxy (e.g. Azure OpenAI)
OPENAI_BASE_URL=

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com

# ── Stripe (optional — remove if not using billing) ───────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...              # monthly plan price ID
STRIPE_PRICE_AMOUNT=2900               # in cents, e.g. 2900 = $29.00
STRIPE_PRICE_CURRENCY=usd
STRIPE_ANNUAL_PRICE_ID=price_...       # annual plan price ID (optional)
STRIPE_ANNUAL_PRICE_AMOUNT=29000       # in cents, e.g. 29000 = $290/year

# ── SMTP / Email (optional — for password reset emails) ───────
# Leave SMTP_HOST empty to log reset links to console instead of sending email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ── LangSmith tracing (optional) ──────────────────────────────
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=LexiCounsel
